generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id             String   @id @default(cuid()) @map("company_id")
  companyName    String   @map("company_name")
  primaryCurrency String  @map("primary_currency") @default("INR")
  country        String
  registrationNo String?  @map("registration_no")
  activeFlag     Boolean  @default(true) @map("active_flag")
  effectiveFrom  DateTime @default(now()) @map("effective_from")
  effectiveTo    DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy      String   @default("SYSTEM") @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  locations          Location[]
  businessGroups     BusinessGroup[]
  businessTypes      BusinessType[]
  legalEntities      LegalEntity[]
  operatingUnits     OperatingUnit[]
  invOrganizations   InvOrganization[]
  hrOrganizations    HrOrganization[]
  grades             Grade[]
  jobs               Job[]
  persons            Person[]
  payrollPeriods     PayrollPeriod[]
  assignmentStatuses AssignmentStatusType[]
  elementTypes       ElementType[]
  absenceTypes       AbsenceType[]
  benefitPlans       BenefitPlan[]
  securityRoles      SecurityRole[]
  securityProfiles   SecurityProfile[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  competences        Competence[]
  holidayCalendars   HolidayCalendar[]
  workSchedules      WorkSchedule[]
  requisitions       Requisition[]
  applicants         Applicant[]
  trainingPrograms   TrainingProgram[]

  @@map("companies")
}

model LocationType {
  id               String   @id @default(cuid()) @map("location_type_id")
  locationTypeName String   @map("location_type_name")
  activeFlag       Boolean  @default(true) @map("active_flag")
  effectiveFrom    DateTime @default(now()) @map("effective_from")
  effectiveTo      DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy        String   @default("SYSTEM") @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  locations Location[]

  @@map("location_types")
}

model Location {
  id             String       @id @default(cuid()) @map("location_id")
  companyId      String       @map("company_id")
  locationTypeId String       @map("location_type_id")
  locationName   String       @map("location_name")
  address1       String?
  city           String?
  state          String?
  country        String?
  pincode        String?
  activeFlag     Boolean      @default(true) @map("active_flag")
  effectiveFrom  DateTime     @default(now()) @map("effective_from")
  effectiveTo    DateTime     @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy      String       @default("SYSTEM") @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")

  company      Company      @relation(fields: [companyId], references: [id])
  locationType LocationType @relation(fields: [locationTypeId], references: [id])

  businessGroups   BusinessGroup[]
  legalEntities    LegalEntity[]
  operatingUnits   OperatingUnit[]
  invOrganizations InvOrganization[]
  hrOrganizations  HrOrganization[]
  positions        Position[]
  holidayCalendars HolidayCalendar[]

  @@map("locations")
}

model BusinessGroup {
  id            String   @id @default(cuid()) @map("bg_id")
  companyId     String   @map("company_id")
  bgLocationId  String   @map("bg_location_id")
  bgName        String   @map("bg_name")
  currencyCode  String   @default("INR") @map("currency_code")
  activeFlag    Boolean  @default(true) @map("active_flag")
  effectiveFrom DateTime @default(now()) @map("effective_from")
  effectiveTo   DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy     String   @default("SYSTEM") @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  company  Company  @relation(fields: [companyId], references: [id])
  location Location @relation(fields: [bgLocationId], references: [id])

  legalEntities    LegalEntity[]
  operatingUnits   OperatingUnit[]
  invOrganizations InvOrganization[]
  hrOrganizations  HrOrganization[]
  grades           Grade[]
  gradeSteps       GradeStep[]
  gradeLadders     GradeLadder[]
  jobs             Job[]
  positions        Position[]
  persons          Person[]
  payrollPeriods   PayrollPeriod[]
  assignments      Assignment[]
  elementTypes     ElementType[]
  absenceTypes     AbsenceType[]
  benefitPlans     BenefitPlan[]
  competences      Competence[]
  holidayCalendars HolidayCalendar[]
  workSchedules    WorkSchedule[]
  requisitions     Requisition[]
  trainingPrograms TrainingProgram[]
  costCenters      CostCenter[]

  @@map("business_groups")
}

model BusinessType {
  id               String   @id @default(cuid()) @map("business_type_id")
  companyId        String   @map("company_id")
  businessTypeName String   @map("business_type_name")
  description      String?
  activeFlag       Boolean  @default(true) @map("active_flag")
  effectiveFrom    DateTime @default(now()) @map("effective_from")
  effectiveTo      DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy        String   @default("SYSTEM") @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  legalEntities    LegalEntity[]
  operatingUnits   OperatingUnit[]
  invOrganizations InvOrganization[]
  hrOrganizations  HrOrganization[]

  @@map("business_types")
}

model LegalEntity {
  id                String   @id @default(cuid()) @map("le_id")
  companyId         String   @map("company_id")
  locationId        String   @map("location_id")
  bgId              String   @map("bg_id")
  businessTypeId    String   @map("business_type_id")
  leName            String   @map("le_name")
  taxRegistrationNo String?  @map("tax_registration_no")
  functionalCurrency String  @default("INR") @map("functional_currency")
  activeFlag        Boolean  @default(true) @map("active_flag")
  effectiveFrom     DateTime @default(now()) @map("effective_from")
  effectiveTo       DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy         String   @default("SYSTEM") @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")

  company      Company      @relation(fields: [companyId], references: [id])
  location     Location     @relation(fields: [locationId], references: [id])
  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])
  businessType BusinessType @relation(fields: [businessTypeId], references: [id])

  operatingUnits   OperatingUnit[]
  invOrganizations InvOrganization[]
  hrOrganizations  HrOrganization[]

  @@map("legal_entities")
}

model OperatingUnit {
  id             String   @id @default(cuid()) @map("ou_id")
  companyId      String   @map("company_id")
  bgId           String   @map("bg_id")
  leId           String   @map("le_id")
  businessTypeId String   @map("business_type_id")
  ouName         String   @map("ou_name")
  ouShortCode    String?  @map("ou_short_code")
  locationId     String   @map("location_id")
  currencyCode   String   @default("INR") @map("currency_code")
  activeFlag     Boolean  @default(true) @map("active_flag")
  effectiveFrom  DateTime @default(now()) @map("effective_from")
  effectiveTo    DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy      String   @default("SYSTEM") @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  company       Company       @relation(fields: [companyId], references: [id])
  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])
  legalEntity   LegalEntity   @relation(fields: [leId], references: [id])
  businessType  BusinessType  @relation(fields: [businessTypeId], references: [id])
  location      Location      @relation(fields: [locationId], references: [id])

  @@map("operating_units")
}

model InvOrganization {
  id             String   @id @default(cuid()) @map("inv_org_id")
  companyId      String   @map("company_id")
  bgId           String   @map("bg_id")
  leId           String   @map("le_id")
  businessTypeId String   @map("business_type_id")
  invOrgName     String   @map("inv_org_name")
  invOrgCode     String   @map("inv_org_code")
  locationId     String   @map("location_id")
  orgType        String?  @map("org_type")
  activeFlag     Boolean  @default(true) @map("active_flag")
  effectiveFrom  DateTime @default(now()) @map("effective_from")
  effectiveTo    DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy      String   @default("SYSTEM") @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  company       Company       @relation(fields: [companyId], references: [id])
  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])
  legalEntity   LegalEntity   @relation(fields: [leId], references: [id])
  businessType  BusinessType  @relation(fields: [businessTypeId], references: [id])
  location      Location      @relation(fields: [locationId], references: [id])

  @@map("inv_organizations")
}

model HrOrganization {
  id             String   @id @default(cuid()) @map("org_id")
  companyId      String   @map("company_id")
  bgId           String   @map("bg_id")
  leId           String   @map("le_id")
  businessTypeId String   @map("business_type_id")
  orgName        String   @map("org_name")
  orgCode        String   @map("org_code")
  locationId     String   @map("location_id")
  orgType        String?  @map("org_type")
  parentOrgId    String?  @map("parent_org_id")
  activeFlag     Boolean  @default(true) @map("active_flag")
  effectiveFrom  DateTime @default(now()) @map("effective_from")
  effectiveTo    DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy      String   @default("SYSTEM") @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  company       Company       @relation(fields: [companyId], references: [id])
  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])
  legalEntity   LegalEntity   @relation(fields: [leId], references: [id])
  businessType  BusinessType  @relation(fields: [businessTypeId], references: [id])
  location      Location      @relation(fields: [locationId], references: [id])
  parentOrg     HrOrganization?  @relation("OrgHierarchy", fields: [parentOrgId], references: [id])
  childOrgs     HrOrganization[] @relation("OrgHierarchy")

  positions   Position[]
  assignments Assignment[]
  elementLinks ElementLink[]
  costCenters  CostCenter[]
  requisitions Requisition[]

  @@map("hr_organizations")
}

model Grade {
  id            String   @id @default(cuid()) @map("grade_id")
  companyId     String   @map("company_id")
  bgId          String   @map("bg_id")
  gradeCode     String   @map("grade_code")
  gradeName     String   @map("grade_name")
  minSalary     Decimal  @default(0) @map("min_salary")
  maxSalary     Decimal  @default(0) @map("max_salary")
  activeFlag    Boolean  @default(true) @map("active_flag")
  effectiveFrom DateTime @default(now()) @map("effective_from")
  effectiveTo   DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy     String   @default("SYSTEM") @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  company       Company       @relation(fields: [companyId], references: [id])
  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])

  gradeSteps    GradeStep[]
  fromLadders   GradeLadder[] @relation("FromGrade")
  toLadders     GradeLadder[] @relation("ToGrade")
  positions     Position[]
  assignments   Assignment[]
  elementLinks  ElementLink[]
  offerLetters  OfferLetter[]
  hiredPersons  HiredPerson[]

  @@map("grades")
}

model GradeStep {
  id            String   @id @default(cuid()) @map("grade_step_id")
  companyId     String   @map("company_id")
  bgId          String   @map("bg_id")
  gradeId       String   @map("grade_id")
  stepNumber    Int      @map("step_number")
  stepName      String   @map("step_name")
  stepAmount    Decimal  @map("step_amount")
  effectiveFrom DateTime @default(now()) @map("effective_from")
  effectiveTo   DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy     String   @default("SYSTEM") @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])
  grade         Grade         @relation(fields: [gradeId], references: [id])

  @@map("grade_steps")
}

model GradeLadder {
  id              String   @id @default(cuid()) @map("ladder_id")
  companyId       String   @map("company_id")
  bgId            String   @map("bg_id")
  ladderName      String   @map("ladder_name")
  fromGradeId     String   @map("from_grade_id")
  toGradeId       String   @map("to_grade_id")
  sequence        Int
  minYearsInGrade Int      @default(0) @map("min_years_in_grade")
  activeFlag      Boolean  @default(true) @map("active_flag")
  effectiveFrom   DateTime @default(now()) @map("effective_from")
  effectiveTo     DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy       String   @default("SYSTEM") @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])
  fromGrade     Grade         @relation("FromGrade", fields: [fromGradeId], references: [id])
  toGrade       Grade         @relation("ToGrade", fields: [toGradeId], references: [id])

  @@map("grade_ladders")
}

model Job {
  id            String   @id @default(cuid()) @map("job_id")
  companyId     String   @map("company_id")
  bgId          String   @map("bg_id")
  jobCode       String   @map("job_code")
  jobName       String   @map("job_name")
  jobFamily     String?  @map("job_family")
  description   String?
  activeFlag    Boolean  @default(true) @map("active_flag")
  effectiveFrom DateTime @default(now()) @map("effective_from")
  effectiveTo   DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy     String   @default("SYSTEM") @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  company       Company       @relation(fields: [companyId], references: [id])
  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])

  positions   Position[]
  assignments Assignment[]

  @@map("jobs")
}

model Position {
  id            String   @id @default(cuid()) @map("position_id")
  companyId     String   @map("company_id")
  bgId          String   @map("bg_id")
  jobId         String   @map("job_id")
  orgId         String   @map("org_id")
  gradeId       String   @map("grade_id")
  locationId    String   @map("location_id")
  positionName  String   @map("position_name")
  headcount     Int      @default(1)
  activeFlag    Boolean  @default(true) @map("active_flag")
  effectiveFrom DateTime @default(now()) @map("effective_from")
  effectiveTo   DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy     String   @default("SYSTEM") @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  businessGroup BusinessGroup  @relation(fields: [bgId], references: [id])
  job           Job            @relation(fields: [jobId], references: [id])
  org           HrOrganization @relation(fields: [orgId], references: [id])
  grade         Grade          @relation(fields: [gradeId], references: [id])
  location      Location       @relation(fields: [locationId], references: [id])

  assignments  Assignment[]
  elementLinks ElementLink[]
  requisitions Requisition[]
  offerLetters OfferLetter[]
  hiredPersons HiredPerson[]

  @@map("positions")
}

model Person {
  id                    String    @id @default(cuid()) @map("person_id")
  companyId             String    @map("company_id")
  bgId                  String    @map("bg_id")
  personType            String    @default("EMP") @map("person_type")
  firstName             String    @map("first_name")
  middleName            String?   @map("middle_name")
  lastName              String    @map("last_name")
  dateOfBirth           DateTime? @map("date_of_birth")
  gender                String?
  nationality           String?
  nationalId            String?   @map("national_id")
  email                 String    @unique
  hireDate              DateTime? @map("hire_date")
  addressType           String?   @map("address_type")
  addressLine1          String?   @map("address_line1")
  city                  String?
  state                 String?
  country               String?
  pincode               String?
  phoneType             String?   @map("phone_type")
  phoneNumber           String?   @map("phone_number")
  phonePreference       String?   @map("phone_preference")
  emergencyName         String?   @map("emergency_name")
  emergencyRelationship String?   @map("emergency_relationship")
  emergencyPhone        String?   @map("emergency_phone")
  emergencyAddress      String?   @map("emergency_address")
  emergencyPriority     Int?      @map("emergency_priority")
  activeFlag            Boolean   @default(true) @map("active_flag")
  effectiveFrom         DateTime  @default(now()) @map("effective_from")
  effectiveTo           DateTime  @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy             String    @default("SYSTEM") @map("created_by")
  createdAt             DateTime  @default(now()) @map("created_at")

  company       Company       @relation(fields: [companyId], references: [id])
  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])

  documents          PersonDocument[]
  assignments        Assignment[]
  absences           Absence[]
  benefitEnrollments BenefitEnrollment[]
  personCompetences  PersonCompetence[]
  payments           Payment[]
  payslips           Payslip[]
  taxDeclarations    TaxDeclaration[]
  loans              Loan[]
  separations        Separation[]
  trainingEnrollments TrainingEnrollment[]
  appraisals         Appraisal[]
  personHistory      PersonHistory[]
  supervisors        Supervisor[]
  supervisorOf       Supervisor[]         @relation("SupervisorPerson")
  securityProfilePersons SecurityProfilePerson[]

  @@map("persons")
}

model PersonDocument {
  id                String    @id @default(cuid()) @map("document_id")
  companyId         String    @map("company_id")
  bgId              String    @map("bg_id")
  personId          String    @map("person_id")
  documentType      String    @map("document_type")
  documentNumber    String?   @map("document_number")
  issuingAuthority  String?   @map("issuing_authority")
  issueDate         DateTime? @map("issue_date")
  expiryDate        DateTime? @map("expiry_date")
  verifiedFlag      Boolean   @default(false) @map("verified_flag")
  qualificationType String?   @map("qualification_type")
  degreeName        String?   @map("degree_name")
  institution       String?
  yearOfPassing     Int?      @map("year_of_passing")
  gradePct          Decimal?  @map("grade_pct")
  companyName       String?   @map("company_name")
  designation       String?
  fromDate          DateTime? @map("from_date")
  toDate            DateTime? @map("to_date")
  reasonForLeaving  String?   @map("reason_for_leaving")
  activeFlag        Boolean   @default(true) @map("active_flag")
  effectiveFrom     DateTime  @default(now()) @map("effective_from")
  effectiveTo       DateTime  @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy         String    @default("SYSTEM") @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id])

  @@map("person_documents")
}

model PayrollPeriod {
  id               String   @id @default(cuid()) @map("pay_period_id")
  companyId        String   @map("company_id")
  bgId             String   @map("bg_id")
  payrollName      String   @map("payroll_name")
  payrollCode      String   @map("payroll_code")
  periodName       String   @map("period_name")
  startDate        DateTime @map("start_date")
  endDate          DateTime @map("end_date")
  status           String   @default("Open")
  periodType       String   @default("Monthly") @map("period_type")
  paymentMethod    String   @default("Bank Transfer") @map("payment_method")
  currencyCode     String   @default("INR") @map("currency_code")
  activeFlag       Boolean  @default(true) @map("active_flag")
  effectiveFrom    DateTime @default(now()) @map("effective_from")
  effectiveTo      DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy        String   @default("SYSTEM") @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  company       Company       @relation(fields: [companyId], references: [id])
  businessGroup BusinessGroup @relation(fields: [bgId], references: [id])

  payrollRuns    PayrollRun[]
  loanRepayments LoanRepayment[]
  assignments    Assignment[]

  @@map("payroll_periods")
}

model AssignmentStatusType {
  id            String   @id @default(cuid()) @map("status_type_id")
  companyId     String   @map("company_id")
  statusCode    String   @map("status_code")
  statusName    String   @map("status_name")
  userStatus    String?  @map("user_status")
  systemStatus  String?  @map("system_status")
  activeFlag    Boolean  @default(true) @map("active_flag")
  effectiveFrom DateTime @default(now()) @map("effective_from")
  effectiveTo   DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy     String   @default("SYSTEM") @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  company     Company      @relation(fields: [companyId], references: [id])
  assignments Assignment[]

  @@map("assignment_status_types")
}

model Assignment {
  id                     String   @id @default(cuid()) @map("assignment_id")
  companyId              String   @map("company_id")
  bgId                   String   @map("bg_id")
  personId               String   @map("person_id")
  orgId                  String   @map("org_id")
  positionId             String?  @map("position_id")
  jobId                  String?  @map("job_id")
  gradeId                String?  @map("grade_id")
  payrollId              String?  @map("payroll_id")
  assignmentStatusTypeId String   @map("assignment_status_type_id")
  assignmentType         String   @default("PRIMARY") @map("assignment_type")
  activeFlag             Boolean  @default(true) @map("active_flag")
  effectiveFrom          DateTime @default(now()) @map("effective_from")
  effectiveTo            DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")
  createdBy              String   @default("SYSTEM") @map("created_by")
  createdAt              DateTime @default(now()) @map("created_at")

  businessGroup        BusinessGroup        @relation(fields: [bgId], references: [id])
  person               Person               @relation(fields: [personId], references: [id])
  org                  HrOrganization       @relation(fields: [orgId], references: [id])
  position             Position?            @relation(fields: [positionId], references: [id])
  job                  Job?                 @relation(fields: [jobId], references: [id])
  grade                Grade?               @relation(fields: [gradeId], references: [id])
  payrollPeriod        PayrollPeriod?       @relation(fields: [payrollId], references: [id])
  assignmentStatusType AssignmentStatusType @relation(fields: [assignmentStatusTypeId], references: [id])

  supervisors    Supervisor[]
  supervisedBy   Supervisor[] @relation("SupervisorAssignment")
  elementEntries ElementEntry[]
  salaries       Salary[]
  runResults     RunResult[]
  payBalances    PayBalance[]
  payments       Payment[]
  payslips       Payslip[]
  taxDeclarations TaxDeclaration[]
  loans          Loan[]
  loanRepayments LoanRepayment[]
  timecards      Timecard[]
  appraisals     Appraisal[]
  separations    Separation[]
  finalSettlements FinalSettlement[]
  benefitEnrollments BenefitEnrollment[]
  personHistory  PersonHistory[]

  @@map("assignments")
}

model Supervisor {
  id                     String   @id @default(cuid()) @map("supervisor_id")
  companyId              String   @map("company_id")
  bgId                   String   @map("bg_id")
  assignmentId           String   @map("assignment_id")
  personId               String   @map("person_id")
  supervisorPersonId     String   @map("supervisor_person_id")
  supervisorAssignmentId String   @map("supervisor_assignment_id")
  activeFlag             Boolean  @default(true) @map("active_flag")
  effectiveFrom          DateTime @default(now()) @map("effective_from")
  effectiveTo            DateTime @default(dbgenerated("'2099-12-31'::date")) @map("effective_to")

  assignment           Assignment @relation(fields: [assignmentId], references: [id])
  person               Person     @relation(fields: [personId], references: [id])
  supervisorPerson     Person     @relation("SupervisorPerson", fields: [supervisorPersonId], references: [id])
  supervisorAssignment Assignment @relation("SupervisorAssignment", fields: [supervisorAssignmentId], references: [id])

  @@map("supervisors")
}



model ElementType {
  id                  String   @id @default(cuid()) @map("element_type_id")
  companyId           String   @map("company_id")
  bgId                String   @map("bg_id")
  elementCode         String   @map("element_code")
  elementName         String   @map("element_name")
  classification      String
  processingPriority  Int      @default(10) @map("processing_priority")
  recurringFlag       Boolean  @default(true) @map("recurring_flag")
  activeFlag          Boolean  @default(true) @map("active_flag")
